# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ── pgAdmin (opcional — profile tools) ────────────────────────────────────────
PGADMIN_EMAIL=admin@ecommerce.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Backend API ───────────────────────────────────────────────────────────────
API_PORT=5080
ASPNETCORE_ENVIRONMENT=Development
JWT_ISSUER=ecommerce-api
JWT_AUDIENCE=ecommerce-web
JWT_SECRET=EcommerceDevSecretKey_Min32Chars_ChangeInProd!
CORS_ORIGIN=http://localhost:4200

# Connection string (uso local sem Docker — host localhost)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ecommerce;Username=ecommerce;Password=changeme

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=4200
